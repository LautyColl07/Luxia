generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases          LegalCase[]
  ownedCases     LegalCase[]        @relation("CaseOwner")
  createdCases   LegalCase[]        @relation("CaseCreator")
  files          File[]
  hearings       Hearing[]
  transcripts    Transcript[]
  studyMembers   LegalStudyMember[]
}

model LegalStudy {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases    LegalCase[]
  members  LegalStudyMember[]
}

model LegalStudyMember {
  id           String   @id @default(cuid())
  legalStudyId String
  userId       String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  legalStudy LegalStudy @relation(fields: [legalStudyId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([legalStudyId, userId])
  @@index([userId])
  @@index([legalStudyId])
}

model LegalCase {
  id           String   @id
  userId       String
  createdById  String?
  ownerUserId  String?
  legalStudyId String?
  title        String
  status       String   @default("pending")
  court        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner       User?       @relation("CaseOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  creator     User?       @relation("CaseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  legalStudy  LegalStudy? @relation(fields: [legalStudyId], references: [id], onDelete: SetNull)
  files       File[]
  hearings    Hearing[]
  transcripts Transcript[]

  @@index([userId])
  @@index([createdById])
  @@index([ownerUserId])
  @@index([legalStudyId])
  @@map("Case")
}

model Hearing {
  id        String    @id
  caseId    String
  userId    String
  title     String?
  date      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  case        LegalCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       File[]
  transcripts Transcript[]

  @@index([caseId])
  @@index([userId])
}

model File {
  id           String   @id @default(cuid())
  hearingId    String
  caseId       String
  userId       String
  fileName     String
  mimeType     String?
  path         String   @db.Text
  documentType String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  case    LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  hearing Hearing   @relation(fields: [hearingId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([hearingId])
  @@index([userId])
}

model Transcript {
  id        String   @id @default(cuid())
  hearingId String
  caseId    String
  userId    String
  text      String   @db.LongText
  audioPath String?  @db.Text
  pdfPath   String?  @db.Text
  status    String   @default("recording")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case    LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  hearing Hearing   @relation(fields: [hearingId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hearingId, userId])
  @@index([caseId])
  @@index([userId])
}

model TranscriptSession {
  id          String   @id @default(cuid())
  title       String?
  status      String   @default("recording")
  caseId      String?
  hearingId   String?
  legalStudyId String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks TranscriptChunk[]

  @@index([createdById])
  @@index([legalStudyId])
}

model TranscriptChunk {
  id         String   @id @default(cuid())
  sessionId  String
  chunkIndex Int
  startTime  Float?
  endTime    Float?
  text       String   @db.Text
  createdAt  DateTime @default(now())

  session TranscriptSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
}

model ActivityLog {
  id                String   @id @default(cuid())
  userId            String
  type              String
  title             String
  description       String
  relatedEntityType String?
  relatedEntityId   String?
  relatedEntityName String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
